# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# Model to use via OpenRouter (default: Claude 3.5 Sonnet — ~€2-3/month at this usage level)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Google Drive folder ID where briefing documents will be saved
# Get this from the URL of the folder: drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Path to Google service account credentials JSON file (for Drive upload)
# See docs/setup_google_drive.md for how to create this
GOOGLE_SERVICE_ACCOUNT_FILE=config/google_service_account.json

# Output directory for briefing documents (local fallback if Drive is not configured)
OUTPUT_DIR=outputs
